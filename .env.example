# ── Frontend (Vite — prefix with VITE_) ──────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Render backend URL (OCR + RAG + LLM relay)
VITE_OCR_API_URL=https://ncec-ocr-backend.onrender.com
VITE_USE_OCR_BACKEND=true

# Optional: override LLM backend URL separately
# VITE_LLM_API_URL=https://ncec-ocr-backend.onrender.com

# Mapbox GL JS token for Interactive Map page
VITE_MAPBOX_TOKEN=your_mapbox_token_here

# ── Render Backend (set in Render dashboard → Environment) ─────────────
# OLLAMA_HOST=http://your-ollama-server:11434
#   → Point to your machine running Ollama with local model weights.
#   → Use ngrok/cloudflare tunnel to expose local Ollama to Render.
#   → Required models: ollama pull qwen2:0.5b && ollama pull nomic-embed-text
#
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
#
# CHAT_MODEL=qwen2:0.5b
# EMBED_MODEL=nomic-embed-text
# PORT=8100
