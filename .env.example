# Set to "true" when connecting to the live PaddleOCR backend on Render.
# Default: client-side OCR in the browser with automatic server fallback.
VITE_USE_OCR_BACKEND=true
VITE_OCR_API_URL=https://ncec-ocr-backend.onrender.com

# Mapbox GL JS access token for the Interactive Map page.
# Get a free token at https://account.mapbox.com/auth/signup/
VITE_MAPBOX_TOKEN=your_mapbox_token_here
