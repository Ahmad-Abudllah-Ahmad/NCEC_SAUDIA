# ── Frontend (Vite — prefix with VITE_) ──────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Render backend URL (OCR + grounded RAG)
VITE_OCR_API_URL=https://ncec-ocr-backend.onrender.com
VITE_USE_OCR_BACKEND=true

# Optional: override LLM backend URL separately
# VITE_LLM_API_URL=https://ncec-ocr-backend.onrender.com

# Mapbox GL JS token for Interactive Map page
VITE_MAPBOX_TOKEN=your_mapbox_token_here

# ── Render Backend (set in Render dashboard → Environment) ─────────────
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
#
# Optional — fluent answers via Gemini (0 MB local weights):
# GEMINI_API_KEY=your_key_from_https://aistudio.google.com/apikey
# CHAT_MODEL=gemini-2.0-flash-lite
# EMBED_MODEL=text-embedding-004
#
# PORT=8100
