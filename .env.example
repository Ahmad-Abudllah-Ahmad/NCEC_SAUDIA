# ── Frontend (Vite — prefix with VITE_) ──────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Render backend URL (OCR + RAG + tiny open-weight LLM)
VITE_OCR_API_URL=https://ncec-ocr-backend.onrender.com
VITE_USE_OCR_BACKEND=true

# Optional: override LLM backend URL separately
# VITE_LLM_API_URL=https://ncec-ocr-backend.onrender.com

# Mapbox GL JS token for Interactive Map page
VITE_MAPBOX_TOKEN=your_mapbox_token_here

# ── Render Backend (set in Render dashboard → Environment) ─────────────
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
#
# CHAT_MODEL=vicuna-68m
# MODEL_DIR=/app/models
# GGUF_NAME=vicuna-68m.Q3_K_S.gguf
# GGUF_URL=https://huggingface.co/Felladrin/gguf-vicuna-68m/resolve/main/vicuna-68m.Q3_K_S.gguf
# PORT=8100
