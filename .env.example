# Set to "true" only when the PaddleOCR backend is running (see server/start.sh on port 8100).
# Default: client-side OCR in the browser (no proxy errors, no extra server needed).
VITE_USE_OCR_BACKEND=false

# Mapbox GL JS access token for the Interactive Map page.
# Get a free token at https://account.mapbox.com/auth/signup/
VITE_MAPBOX_TOKEN=your_mapbox_token_here
